{
  "name": "aurion-music-player",
  "version": "1.0.0",
  "description": "Beautiful music player",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --linux --win"
  },
  "author": "Rishu",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.aurion.player",
    "productName": "Aurion",
    "linux": {
      "target": ["AppImage"],
      "category": "AudioVideo",
      "icon": "icon.png"
    },
    "win": {
      "target": ["portable"],
      "icon": "icon.png"
    },
    "files": [
      "index.html",
      "main.js",
      "icon.png"
    ]
  }
}